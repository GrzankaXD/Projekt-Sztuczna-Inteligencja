{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Liczba zapytań /query",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "app_queries_total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Uruchomienia pipeline",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "app_pipeline_runs_total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency /query (średnia z 1m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(app_request_latency_seconds_sum{endpoint=\"/query\"}[1m]) / rate(app_request_latency_seconds_count{endpoint=\"/query\"}[1m])",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Zaindeksowane rekordy",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "app_indexed_records",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["rag", "air-quality"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "title": "RAG Air Quality Dashboard",
  "version": 1
}
